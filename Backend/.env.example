PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=makulu_church
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=10m
JWT_REFRESH_EXPIRES_IN=10m
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
PASSWORD_RESET_URL_BASE=http://localhost:5173/admin/login
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Makulu Admin
SMTP_FROM_EMAIL=your-email@example.com
API_CACHE_TTL_MS=30000
UPLOADS_DIR=./uploads
